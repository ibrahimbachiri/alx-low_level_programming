#include <stdio.h>

/**                                                                                                                                                 
 * main - Entry point of the program                                                                                                                
 *                                                                                                                                                  
 * Description: Prints the alphabet in lowercase                                                                                                    
 * Return: Always 0 (Success)                                                                                                                       
 */
int main(void)
{
        char letter;

        /* Loop through the lowercase alphabet */
        for (letter = 'a'; letter <= 'z'; letter++)
                putchar(letter);

        return (0);
}

